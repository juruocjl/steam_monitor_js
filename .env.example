# API 端口
PORT=3000

# Steam 本地化语言（默认 schinese）
STEAM_LANGUAGE=schinese

# SQLite 数据库文件路径（可选）
SQLITE_DB_PATH=./data/friend_game_history.db

# Steam 商店请求代理（可选）
HTTPS_PROXY=

# Steam 商店请求超时与重试配置（可选）
STEAM_STORE_TIMEOUT_MS=5000
STEAM_STORE_RETRY_TIMES=3
STEAM_STORE_RETRY_DELAY_MS=800

# 登录方式 1（推荐长期运行）
# 使用 refresh token 自动登录
STEAM_REFRESH_TOKEN=

# 登录方式 2
# 使用账号密码登录
STEAM_ACCOUNT_NAME=
STEAM_PASSWORD=
# 若密码包含 #，可直接填写；程序会按原始值读取

# 可选：机器名标识
STEAM_MACHINE_NAME=steam-monitor-js
